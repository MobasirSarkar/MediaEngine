# env
APP_ENV=dev
HTTP_ADDR=:8080
LOG_LEVEL=debug
LOG_FORMAT=console

# db
DB_DSN=postgres://pipeline:pipeline@localhost:5432/pipeline?sslmode=disable

# nats
NATS_URL=nats://localhost:4222

# s3 / minio
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_UPLOADS=uploads
S3_BUCKET_MEDIA=media
S3_PRESIGN_TTL=15m

# uploads
UPLOAD_CHUNK_SIZE_MIN=5242880
UPLOAD_CHUNK_SIZE_MAX=52428800
UPLOAD_SESSION_TTL=24h
